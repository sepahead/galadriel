{
  "$defs": {
    "profile_identity": {
      "additionalProperties": false,
      "properties": {
        "profile_digest": {
          "$ref": "#/$defs/sha256"
        },
        "profile_id": {
          "pattern": "^[a-z][a-z0-9._-]{0,127}$",
          "type": "string"
        },
        "profile_revision": {
          "maxLength": 64,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "profile_id",
        "profile_revision",
        "profile_digest"
      ],
      "type": "object"
    },
    "session": {
      "additionalProperties": false,
      "properties": {
        "epoch": {
          "maxLength": 128,
          "minLength": 16,
          "type": "string"
        },
        "generation": {
          "maximum": 18446744073709551615,
          "minimum": 0,
          "type": "integer"
        },
        "session_id": {
          "maxLength": 128,
          "minLength": 16,
          "type": "string"
        }
      },
      "required": [
        "session_id",
        "epoch",
        "generation"
      ],
      "type": "object"
    },
    "sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "software_identity": {
      "additionalProperties": false,
      "properties": {
        "build_digest": {
          "$ref": "#/$defs/sha256"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        "source_commit": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "version": {
          "pattern": "^1\\.0\\.0(?:[-+][0-9A-Za-z.-]+)?$",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "source_commit",
        "build_digest"
      ],
      "type": "object"
    },
    "stream_position": {
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "maximum": 18446744073709551615,
          "minimum": 0,
          "type": "integer"
        },
        "stream_id": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "stream_id",
        "sequence"
      ],
      "type": "object"
    },
    "timestamps": {
      "additionalProperties": false,
      "properties": {
        "clock_domain": {
          "enum": [
            "unix_utc",
            "monotonic_process",
            "simulation_time",
            "tai"
          ]
        },
        "receipt_ns": {
          "maximum": 9223372036854775807,
          "minimum": 0,
          "type": "integer"
        },
        "source_ns": {
          "maximum": 9223372036854775807,
          "minimum": 0,
          "type": "integer"
        },
        "uncertainty_ns": {
          "maximum": 9223372036854775807,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "source_ns",
        "receipt_ns",
        "clock_domain"
      ],
      "type": "object"
    }
  },
  "$id": "https://sepahead.example/schemas/galadriel-core-envelope-1.0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Implementation design target. The agent must reconcile it with the final normative repository schema and retain compatibility vectors.",
  "properties": {
    "$id": {
      "type": "string"
    },
    "$schema": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "advisory": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "availability": {
                "not": {
                  "const": "ready"
                }
              }
            }
          },
          "then": {
            "properties": {
              "disposition": {
                "not": {
                  "const": "nominal"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "policy_effect": {
                "const": "restrict_only"
              }
            }
          },
          "then": {
            "required": [
              "statistical_profile_digest"
            ]
          }
        }
      ],
      "properties": {
        "availability": {
          "enum": [
            "ready",
            "partial",
            "stale",
            "unavailable",
            "incompatible"
          ]
        },
        "calibrated_posterior": {
          "const": false
        },
        "channels": {
          "items": {
            "type": "string"
          },
          "maxItems": 64,
          "type": "array",
          "uniqueItems": true
        },
        "disposition": {
          "enum": [
            "nominal",
            "attributed_inconsistency",
            "broad_degradation",
            "unclassified_anomaly",
            "insufficient_evidence"
          ]
        },
        "policy_effect": {
          "enum": [
            "none",
            "record_only",
            "restrict_only"
          ]
        },
        "statistical_profile_digest": {
          "$ref": "#/$defs/sha256"
        }
      },
      "required": [
        "disposition",
        "policy_effect",
        "availability",
        "calibrated_posterior"
      ],
      "type": "object"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
      },
      "type": "object"
    },
    "payload_digest": {
      "$ref": "#/$defs/sha256"
    },
    "profile_identity": {
      "$ref": "#/$defs/profile_identity"
    },
    "reason_codes": {
      "items": {
        "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
        "type": "string"
      },
      "maxItems": 64,
      "type": "array",
      "uniqueItems": true
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "session": {
      "$ref": "#/$defs/session"
    },
    "software_identity": {
      "$ref": "#/$defs/software_identity"
    },
    "status": {
      "enum": [
        "valid",
        "invalid",
        "insufficient",
        "denied",
        "error"
      ]
    },
    "stream_position": {
      "$ref": "#/$defs/stream_position"
    },
    "timestamps": {
      "$ref": "#/$defs/timestamps"
    }
  },
  "required": [
    "schema_version",
    "software_identity",
    "profile_identity",
    "session",
    "stream_position",
    "timestamps",
    "status",
    "reason_codes",
    "payload_digest",
    "advisory"
  ],
  "title": "Galadriel 1.0 core 1.0 envelope design target",
  "type": "object"
}