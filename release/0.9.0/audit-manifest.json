  "claims": [
    {
      "claim": "The pure core validates finite per-observation NIS inputs and produces evidence-neutral magnitude verdicts with typed invalid-input failures.",
      "evidence": [
        "crates/galadriel-core/src/decision.rs",
        "release/0.9.0/evidence/baseline-workspace-all-features.log"
      ],
      "id": "CLM-001",
      "limitations": "Implementation does not authenticate physical truth, identify attack cause, or establish a calibrated false-alert rate.",
      "scope": "galadriel-core source behavior under its validated configuration and bounded inputs",
      "tier": "IMPLEMENTED"
    },
    {
      "claim": "Cross-channel correlation uses only sequence-aligned producer-declared common projections with matching frame, context, and frozen-prior provenance.",
      "evidence": [
        "crates/galadriel-core/src/lib.rs",
        "release/0.9.0/evidence/baseline-workspace-all-features.log"
      ],
      "id": "CLM-002",
      "limitations": "Producer-attested means a provenance claim; cryptographic authenticity exists only when an independently configured transport binds publisher identity.",
      "scope": "galadriel-core projection extraction and default correlation path",
      "tier": "IMPLEMENTED"
    },
    {
      "claim": "The NCP adapters bound JSONL/live state, validate versioned producer and lifecycle envelopes, and retain explicit typed terminal faults.",
      "evidence": [
        "crates/galadriel-ncp/src",
        "release/0.9.0/evidence/baseline-workspace-all-features.log"
      ],
      "id": "CLM-003",
      "limitations": "No external actual-binary mTLS/ACL campaign or NCP 1.0 conformance is claimed.",
      "scope": "galadriel-ncp component and in-process receiver behavior at the exact NCP 0.8 pin",
      "tier": "IMPLEMENTED"
    },
    {
      "claim": "The checked-in synthetic and fixture test suites pass on the recorded Rust 1.89 macOS arm64 baseline.",
      "evidence": [
        "release/0.9.0/evidence/baseline-workspace-all-features.log"
      ],
      "id": "CLM-004",
      "limitations": "A passing component suite is not independent field validation, a performance guarantee, or evidence for untested platforms.",
      "scope": "exact baseline commit, lockfile, toolchain, commands, seeds, fixtures and in-process transports recorded by the audit manifest",
      "tier": "VALIDATED"
    },
    {
      "claim": "Galadriel output is advisory evidence that cannot grant or widen authority under the machine-testable consumer-effect contract.",
      "evidence": [
        "crates/galadriel-core/src/authority.rs",
        "docs/ADVISORY-BOUNDARY.md"
      ],
      "id": "CLM-005",
      "limitations": "No downstream consumer adapter is included or qualified in 0.9.0.",
      "scope": "galadriel-core advisory authority model and documented consumer contract",
      "tier": "IMPLEMENTED"
    },
    {
      "claim": "Galadriel establishes sensor truth, attack intent, or a calibrated posterior probability.",
      "evidence": [],
      "id": "CLM-006",
      "limitations": "Consistency can be preserved by coordinated or moment-matched compromise; every release output remains calibrated_posterior=false.",
      "scope": "all detectors, reports and integrations",
      "tier": "NOT_CLAIMED"
    },
    {
      "claim": "The default profile meets a deployment false-alert, detection, latency, or availability acceptance threshold.",
      "evidence": [],
      "id": "CLM-007",
      "limitations": "Existing retained evidence is diagnostic and includes unacceptable repeated-look false alerts and missingness abstention.",
      "scope": "operational, field, mission and safety performance",
      "tier": "NOT_CLAIMED"
    },
    {
      "claim": "Galadriel 0.9.0 is qualified on NCP 1.0 or on a released pid-rs 1.x artifact.",
      "evidence": [],
      "id": "CLM-008",
      "limitations": "The selected NCP dependency is immutable v0.8.0; the pid-rs revision is immutable but lacks an upstream v1 release tag/artifact.",
      "scope": "optional ecosystem dependencies",
      "tier": "NOT_CLAIMED"
    },
    {
      "claim": "Crebain, Haldir, Prisoma or Paper2Brain provides a deployment-qualified Galadriel 0.9.0 integration.",
      "evidence": [],
      "id": "CLM-009",
      "limitations": "Only the Crebain reciprocal component fixture exists; no accepted recorded projected stream, downstream adapter, or secured deployment campaign exists.",
      "scope": "cross-repository ecosystem composition",
      "tier": "NOT_CLAIMED"
    },
    {
      "claim": "Galadriel 0.9.0 crates are published on crates.io or carry a production-support promise.",
      "evidence": [],
      "id": "CLM-010",
      "limitations": "All workspace packages remain publish=false; 0.9.0 is a GitHub source release for supervisor review.",
      "scope": "package publication and operational support",
      "tier": "NOT_CLAIMED"
    },
    {
      "claim": "Galadriel 0.9.0 has a project DOI or Zenodo record.",
      "evidence": [],
      "id": "CLM-011",
      "limitations": "The author will add DOI/Zenodo metadata only after this supervisor-review release.",
      "scope": "citation and archival identity",
      "tier": "NOT_CLAIMED"
    }
